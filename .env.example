# ── Supabase (client-safe; these ship to the browser) ──────────────────
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# New-style publishable key (starts with sb_publishable_…). Preferred.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR-KEY
# Legacy anon key still works as a fallback if you use the old format instead:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Public site URL — used for magic-link / OAuth redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Login captcha (Cloudflare Turnstile) ──────────────────────────────
# Optional but STRONGLY recommended in production. When set, the login /
# signup / magic-link forms render a Turnstile widget and send its token as
# `captchaToken` on every auth call — the app-side throttle against scripted
# credential stuffing and magic-link mail-bombing. Leave unset for local dev:
# the forms then work exactly as before with no captcha.
#
# To enable, ALSO turn on captcha in the Supabase dashboard so the token is
# verified server-side: Auth → Settings → "Enable Captcha protection",
# provider = Turnstile, and paste the Turnstile *secret* key there. Tighten
# Auth → Rate Limits (sign-in / token / OTP per IP + per email) at the same
# time — the captcha and those limits are complementary defenses.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── Server-only secrets (NEVER prefix with NEXT_PUBLIC_) ───────────────
# Optional: only needed for admin scripts / seeding. Leave unset for the app.
# SUPABASE_SERVICE_ROLE_KEY=
