# ── Supabase (client-safe; these ship to the browser) ──────────────────
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# New-style publishable key (starts with sb_publishable_…). Preferred.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR-KEY
# Legacy anon key still works as a fallback if you use the old format instead:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Public site URL — used for magic-link / OAuth redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Server-only secrets (NEVER prefix with NEXT_PUBLIC_) ───────────────
# Optional: only needed for admin scripts / seeding. Leave unset for the app.
# SUPABASE_SERVICE_ROLE_KEY=
