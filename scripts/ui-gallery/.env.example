# UI Gallery — optional overrides. You do NOT need this file for local use:
#   • populated pass: the tool sets a known dev password on the local account
#     itself (pgcrypto), so no secret is required.
#   • empty pass: a throwaway account is auto-signed-up.
# Copy to `.env` (gitignored) only to override the defaults below.

# Populated account (default password is set on it automatically — see provision.ts).
# GALLERY_EMAIL=climber@basecamp.dev
# GALLERY_PASSWORD=pathwarden-ui-gallery

# Where the running app is served (local dev convention is :3001).
# GALLERY_BASE_URL=http://localhost:3001

# Local Supabase Postgres (only used to set the populated password; must be local).
# GALLERY_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Throwaway account for the "empty" data pass (auto-created on first run).
# GALLERY_EMPTY_EMAIL=gallery-empty@basecamp.dev
# GALLERY_EMPTY_PASSWORD=gallery-empty-pw-2401
